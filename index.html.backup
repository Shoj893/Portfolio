<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shobhit Jaiswal Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <!-- ... -->
</body>
</html>
      transition: all 0.3s ease;
    }
    #navbar.scrolled {
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(20px);
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 48px;
      display: flex; justify-content: space-between; align-items: center;
    }
    @media(max-width:768px){ .nav-inner { padding: 0 24px; } }
    .nav-logo {
      font-family: var(--font-display); font-size: 1.5rem; font-weight: 900;
      text-decoration: none; cursor: pointer;
    }
    .nav-logo span:first-child { color: var(--white); }
    .nav-logo span:last-child { color: var(--orange); }
    .nav-links {
      display: flex; align-items: center; gap: 32px; list-style: none;
    }
    @media(max-width:768px){ .nav-links { display: none; } }
    .nav-links a {
      text-decoration: none; font-size: 0.875rem; font-weight: 500;
      color: var(--gray); transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-hire {
      padding: 8px 20px; border-radius: 100px;
      border: 1px solid var(--orange); color: var(--orange);
      text-decoration: none; font-size: 0.875rem; font-weight: 600;
      transition: all 0.3s;
    }
    .nav-hire:hover { background: var(--orange); color: var(--white); }
    .nav-hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; background: none; border: none; padding: 4px;
    }
    @media(max-width:768px){ .nav-hamburger { display: flex; } }
    .nav-hamburger span {
      display: block; width: 24px; height: 2px;
      background: var(--white); border-radius: 2px;
      transition: all 0.3s;
    }
    .mobile-menu {
      display: none; flex-direction: column; gap: 16px;
      background: rgba(0,0,0,0.7); backdrop-filter: blur(20px);
      border-top: 1px solid var(--border);
      padding: 24px;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-size: 1.1rem; font-weight: 500;
      color: var(--gray); text-decoration: none; transition: color 0.2s;
    }
    .mobile-menu a:hover { color: var(--orange); }

    /* ─── HERO ─── */
    #home {
      position: relative; min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      overflow: hidden; background: hsl(222, 47%, 4%);
    }
    #particle-canvas {
      position: absolute; inset: 0;
      pointer-events: none; z-index: 0;
    }
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1; pointer-events: none;
      background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(10,14,30,0.30) 0%, rgba(6,10,22,0.60) 100%);
    }
    .hero-content {
      position: relative; z-index: 10;
      display: flex; flex-direction: column; align-items: center;
      text-align: center; padding: 0 24px; max-width: 900px; margin: 0 auto;
    }
    .hero-chip {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 16px; border-radius: 100px;
      border: 1px solid rgba(255,106,0,0.3);
      background: rgba(255,106,0,0.1);
      color: var(--orange); font-size: 0.875rem; font-weight: 500;
      margin-bottom: 32px;
      animation: fadeDown 0.6s ease 0.1s both;
    }
    .hero-chip-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--orange);
      animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

    .hero-name {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(2.8rem, 8vw, 7rem);
      line-height: 1; letter-spacing: -0.01em;
      margin-bottom: 24px;
      animation: fadeUp 0.8s ease 0.25s both;
    }
    .hero-name .cyan-grad {
      background: linear-gradient(90deg, #ffffff 0%, #00e5ff 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .hero-subtitle {
      font-size: clamp(1.1rem, 3vw, 1.75rem);
      font-weight: 700; color: var(--orange);
      margin-bottom: 24px;
      animation: fadeUp 0.7s ease 0.4s both;
    }
    .hero-tagline {
      font-size: 1rem; color: var(--gray);
      max-width: 600px; line-height: 1.7; margin-bottom: 48px;
      animation: fadeUp 0.7s ease 0.55s both;
    }
    .hero-buttons {
      display: flex; flex-direction: column; align-items: center;
      gap: 16px; width: 100%; max-width: 480px;
      animation: fadeUp 0.7s ease 0.7s both;
    }
    .hero-row { display: flex; gap: 16px; width: 100%; }
    @media(max-width:520px){ .hero-row { flex-direction: column; } }
    .btn {
      flex: 1; display: flex; align-items: center; justify-content: center;
      gap: 10px; padding: 16px 28px; border-radius: 12px;
      font-weight: 700; font-size: 0.95rem; cursor: pointer;
      text-decoration: none; border: none; transition: transform 0.3s;
    }
    .btn:hover { transform: translateY(-3px); }
    .btn-primary {
      background: linear-gradient(135deg, #ff6a00, #ee0979);
      color: var(--white);
      box-shadow: 0 0 30px rgba(255,106,0,0.45);
    }
    .btn-outline {
      background: transparent; color: var(--white);
      border: 2px solid rgba(255,255,255,0.3);
    }
    .btn-outline:hover { background: rgba(255,255,255,0.05); }
    .btn-contact {
      width: 288px; background: transparent; color: var(--white);
      border: 2px solid rgba(255,255,255,0.3);
    }
    .btn-contact:hover { background: rgba(255,255,255,0.05); }
    .scroll-hint {
      position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      color: var(--gray); z-index: 10;
      animation: fadeIn 1s ease 1.4s both;
    }
    .scroll-hint span { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 3px; }
    .scroll-arrow { animation: bounce 1.5s ease-in-out infinite; }
    @keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeDown { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }

    /* ─── ABOUT ─── */
    #about { padding: 96px 0; position: relative; overflow: hidden; }
    .about-glow-1 {
      position: absolute; top: 50%; left: 25%;
      width: 384px; height: 384px; border-radius: 50%;
      background: rgba(255,106,0,0.05); filter: blur(120px);
      pointer-events: none;
    }
    .about-glow-2 {
      position: absolute; top: 33%; right: 25%;
      width: 384px; height: 384px; border-radius: 50%;
      background: rgba(0,229,255,0.05); filter: blur(120px);
      pointer-events: none;
    }
    .section-eyebrow {
      font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 4px;
      color: var(--orange); margin-bottom: 12px;
    }
    .section-title {
      font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 900; margin-bottom: 0;
    }
    .grad-text {
      background: linear-gradient(90deg, var(--orange), var(--cyan));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .about-grid {
      display: grid; grid-template-columns: 320px 1fr; gap: 56px;
      align-items: start; margin-top: 64px;
    }
    @media(max-width:900px){ .about-grid { grid-template-columns: 1fr; } }

    /* Photo Frame */
    .photo-col { display: flex; flex-direction: column; align-items: center; gap: 24px; }
    .photo-frame-wrap { position: relative; }
    .photo-frame-border {
      position: absolute; inset: -3px; border-radius: 16px; z-index: 0;
      background: linear-gradient(135deg, #ff6a00, #00e5ff, #ff6a00);
      background-size: 300% 300%;
      animation: gradientShift 4s ease infinite;
      box-shadow: 0 0 30px rgba(255,106,0,0.4), 0 0 60px rgba(0,229,255,0.15);
    }
    @keyframes gradientShift {
      0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%}
    }
    .photo-area {
      position: relative; z-index: 1;
      width: 260px; height: 300px; border-radius: 16px;
      background: hsl(222,47%,8%);
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .photo-area:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 30px rgba(255,106,0,0.3), 0 0 60px rgba(0,229,255,0.1);
    }
    @media(min-width:900px){ .photo-area { width: 280px; height: 320px; } }
    .photo-area img { width:100%; height:100%; object-fit:cover; display:block; }
    .photo-overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.6);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 8px;
      opacity: 0; transition: opacity 0.3s;
    }
    .photo-area:hover .photo-overlay { opacity: 1; }
    .photo-placeholder {
      display: flex; flex-direction: column;
      align-items: center; gap: 16px;
      padding: 24px; text-align: center;
    }
    .photo-icon-ring {
      width: 80px; height: 80px; border-radius: 50%;
      border: 2px dashed rgba(255,106,0,0.5);
      background: rgba(255,255,255,0.05);
      display: flex; align-items: center; justify-content: center;
    }
    .photo-browse {
      padding: 8px 16px; border-radius: 100px;
      border: 1px solid rgba(255,106,0,0.4);
      color: var(--orange); font-size: 0.75rem; font-weight: 600;
    }
    .photo-name { text-align: center; }
    .photo-name h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; }
    .photo-name p { color: var(--orange); font-size: 0.85rem; margin-top: 4px; }

    /* Stats */
    .stats-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px; width: 100%;
    }
    .stat-card {
      padding: 16px; border-radius: 12px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(135deg, rgba(255,106,0,0.05), rgba(0,229,255,0.05));
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
    }
    .stat-card:hover::before { opacity: 1; }
    .stat-card:hover { 
      transform: translateY(-4px) scale(1.02);
      border-color: rgba(255,106,0,0.3);
      box-shadow: 0 8px 25px rgba(255,106,0,0.2), 0 0 20px rgba(0,229,255,0.1);
    }
    .stat-card .stat-icon { margin-bottom: 8px; }
    .stat-card .stat-value {
      font-family: var(--font-display); font-size: 1.6rem;
      font-weight: 900; line-height: 1; margin-bottom: 4px;
    }
    .stat-card .stat-label { font-size: 0.75rem; color: var(--gray); }

    /* About text */
    .about-text { display: flex; flex-direction: column; gap: 24px; padding-top: 8px; }
    .about-text p { font-size: 1.05rem; color: var(--gray); line-height: 1.8; }
    .about-text strong { color: var(--white); }
    .quote-block {
      padding: 24px; border-radius: 16px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      border-left: 4px solid var(--orange);
    }
    .quote-block p { color: var(--white); font-style: italic; }
    .currently-tags { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
    .currently-tags span.label { font-size: 0.875rem; font-weight: 600; color: var(--white); }
    .tag {
      padding: 6px 12px; border-radius: 100px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      font-size: 0.75rem;
    }
    .tag-cyan { color: var(--cyan); }
    .tag-orange { color: var(--orange); }
    .tag-gray { color: var(--gray); }

    /* ─── SKILLS ─── */
    #skills { padding: 96px 0; background: rgba(0,0,0,0.2); }
    .skills-header {
      display: flex; flex-wrap: wrap;
      justify-content: space-between; align-items: flex-end;
      gap: 24px; margin-bottom: 64px;
    }
    .skills-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; }
    .skills-subtitle { color: var(--gray); margin-top: 12px; max-width: 400px; }
    .skill-tabs {
      display: flex; flex-wrap: wrap; gap: 6px;
      padding: 6px; border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
    }
    .skill-tab {
      padding: 10px 20px; border-radius: 12px;
      font-size: 0.875rem; font-weight: 500;
      color: var(--gray); background: none; border: none;
      cursor: pointer; transition: all 0.3s; position: relative;
    }
    .skill-tab.active {
      color: var(--white);
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
    }
    .skills-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 20px;
    }
    .skill-card {
      padding: 24px; border-radius: 16px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      transition: all 0.3s;
    }
    .skill-card:hover { border-color: rgba(255,255,255,0.2); transform: translateY(-2px); }
    .skill-card-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 16px;
    }
    .skill-card-header h4 { font-size: 1rem; font-weight: 700; }
    .skill-card-header span { font-family: monospace; font-size: 0.875rem; color: var(--orange); }
    .skill-bar-bg {
      height: 6px; background: rgba(255,255,255,0.05); border-radius: 100px; overflow: hidden;
    }
    .skill-bar {
      height: 100%; border-radius: 100px;
      background: linear-gradient(90deg, var(--orange), var(--cyan));
      width: 0; transition: width 1.2s ease;
    }

    /* ─── PROJECTS ─── */
    #projects { padding: 96px 0; }
    .projects-header { text-align: center; margin-bottom: 64px; }
    .projects-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; margin-bottom: 24px; }
    .filter-tabs { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; }
    .filter-tab {
      padding: 8px 24px; border-radius: 100px;
      font-size: 0.875rem; font-weight: 500;
      background: none; cursor: pointer; transition: all 0.3s;
      border: 1px solid rgba(255,255,255,0.1); color: var(--gray);
    }
    .filter-tab.active {
      border-color: var(--orange);
      background: rgba(255,106,0,0.1);
      color: var(--orange);
      box-shadow: 0 0 20px rgba(255,106,0,0.25);
    }
    .filter-tab:hover:not(.active) { border-color: rgba(255,255,255,0.3); color: var(--white); }
    .projects-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 32px;
    }
    .project-card {
      border-radius: 16px; overflow: hidden;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      display: flex; flex-direction: column;
      transition: all 0.4s; cursor: default;
    }
    .project-card:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.2); }
    .project-thumb {
      height: 180px; position: relative; overflow: hidden;
    }
    .project-actions {
      position: absolute; top: 16px; right: 16px;
      display: flex; gap: 8px;
      opacity: 0; transform: translateY(-8px);
      transition: all 0.3s;
    }
    .project-card:hover .project-actions { opacity: 1; transform: translateY(0); }
    .project-action-btn {
      width: 32px; height: 32px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; font-size: 0.9rem; border: none; cursor: pointer;
      transition: all 0.2s;
    }
    .project-action-btn.github {
      background: rgba(0,0,0,0.7); color: var(--white);
      border: 1px solid rgba(255,255,255,0.1);
    }
    .project-action-btn.demo { background: var(--orange); color: var(--white); }
    .project-body { padding: 24px; flex: 1; display: flex; flex-direction: column; }
    .project-cat { font-family: monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: var(--orange); margin-bottom: 8px; }
    .project-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 12px; transition: color 0.3s; }
    .project-card:hover .project-title { color: var(--orange); }
    .project-desc { font-size: 0.875rem; color: var(--gray); line-height: 1.6; flex: 1; margin-bottom: 20px; }
    .project-stack { display: flex; flex-wrap: wrap; gap: 6px; }
    .project-tech {
      padding: 4px 10px; border-radius: 6px; font-size: 0.75rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--gray);
    }
    .hidden-card { display: none; }

    /* ─── EXPERIENCE ─── */
    #experience { padding: 96px 0; background: rgba(0,0,0,0.2); }
    .experience-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; text-align: center; margin-bottom: 80px; }
    .timeline { position: relative; max-width: 800px; margin: 0 auto; }
    .timeline-line {
      position: absolute; left: 28px; top: 0; bottom: 0; width: 2px;
      background: linear-gradient(to bottom, var(--orange), var(--cyan), transparent);
      opacity: 0.3;
    }
    @media(min-width:768px){
      .timeline-line { left: 50%; transform: translateX(-50%); }
    }
    .timeline-item {
      position: relative; margin-bottom: 48px;
      display: flex; align-items: flex-start;
    }
    .timeline-node {
      position: absolute; left: 28px; top: 0;
      width: 40px; height: 40px; border-radius: 50%;
      background: rgba(255,255,255,0.04);
      border: 2px solid rgba(255,106,0,0.5);
      box-shadow: 0 0 20px rgba(255,106,0,0.3);
      display: flex; align-items: center; justify-content: center;
      z-index: 1; transform: translateX(-50%);
    }
    @media(min-width:768px){
      .timeline-node { left: 50%; }
    }
    .timeline-content {
      margin-left: 60px; width: 100%;
    }
    @media(min-width:768px){
      .timeline-item:nth-child(odd) .timeline-content {
        margin-left: 0; width: 45%;
        padding-right: 48px; text-align: right;
      }
      .timeline-item:nth-child(even) .timeline-content {
        margin-left: auto; width: 45%;
        padding-left: 48px;
      }
    }
    .timeline-card {
      padding: 24px; border-radius: 16px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      transition: transform 0.3s;
    }
    .timeline-card:hover { transform: translateY(-4px); }
    .timeline-year {
      display: inline-block; padding: 4px 12px; border-radius: 100px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      font-family: monospace; font-size: 0.75rem;
      color: var(--orange); margin-bottom: 12px;
    }
    .timeline-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
    .timeline-card h4 { font-size: 0.875rem; font-weight: 500; color: var(--gray); margin-bottom: 16px; }
    .timeline-card p { font-size: 0.875rem; color: rgba(138,154,181,0.85); line-height: 1.7; }

    /* ─── CONTACT ─── */
    #contact { padding: 96px 0; position: relative; overflow: hidden; }
    .contact-glow {
      position: absolute; bottom: 0; right: 0;
      width: 500px; height: 500px; border-radius: 50%;
      background: rgba(255,106,0,0.1); filter: blur(150px);
      pointer-events: none;
    }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
    }
    @media(max-width:900px){ .contact-grid { grid-template-columns: 1fr; } }
    .contact-heading {
      font-family: var(--font-display); font-weight: 900;
      font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1.1;
      margin-bottom: 24px;
    }
    .contact-sub { font-size: 1.05rem; color: var(--gray); margin-bottom: 48px; max-width: 360px; line-height: 1.7; }
    .contact-info { display: flex; flex-direction: column; gap: 24px; margin-bottom: 48px; }
    .contact-info-item { display: flex; align-items: center; gap: 16px; }
    .contact-info-icon {
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(255,255,255,0.04);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .contact-info-item p { font-size: 0.8rem; color: var(--gray); }
    .contact-info-item a, .contact-info-item span {
      font-size: 1rem; font-weight: 500; color: var(--white);
      text-decoration: none; transition: color 0.2s;
    }
    .contact-info-item a:hover { color: var(--orange); }
    .social-links { display: flex; gap: 12px; }
    .social-btn {
      width: 48px; height: 48px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.1);
      display: flex; align-items: center; justify-content: center;
      color: var(--gray); text-decoration: none; font-size: 1.1rem;
      transition: all 0.3s;
    }
    .social-btn:hover { color: var(--white); transform: translateY(-4px); background: rgba(255,255,255,0.05); }
    .contact-form {
      padding: 32px; border-radius: 24px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      display: flex; flex-direction: column; gap: 24px;
    }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: 0.875rem; font-weight: 500; color: var(--gray); }
    .form-group input, .form-group textarea {
      background: rgba(0,0,0,0.2);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px; padding: 14px 16px;
      color: var(--white); font-family: var(--font-body);
      font-size: 0.9rem; outline: none;
      transition: border-color 0.3s;
    }
    .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(138,154,181,0.5); }
    .form-group input:focus, .form-group textarea:focus { border-color: rgba(255,106,0,0.5); }
    .form-group textarea { resize: none; }
    .btn-send {
      width: 100%; padding: 16px; border-radius: 12px;
      background: linear-gradient(135deg, #ff6a00, #ee0979);
      color: var(--white); font-weight: 700; font-size: 0.95rem;
      border: none; cursor: pointer; display: flex; align-items: center;
      justify-content: center; gap: 8px;
      box-shadow: 0 0 30px rgba(255,106,0,0.4);
      transition: all 0.3s;
    }
    .btn-send:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(255,106,0,0.6); }
    .btn-send:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
    .spinner {
      width: 20px; height: 20px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: white;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ─── FOOTER ─── */
    footer {
      padding: 32px 0;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    .footer-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 48px;
      display: flex; flex-wrap: wrap;
      justify-content: space-between; align-items: center; gap: 16px;
    }
    @media(max-width:768px){ .footer-inner { padding: 0 24px; flex-direction: column; text-align: center; } }
    .footer-logo { font-family: var(--font-display); font-size: 1.25rem; font-weight: 900; }
    .footer-logo span:first-child { color: var(--white); }
    .footer-logo span:last-child { color: var(--orange); }
    .footer-copy { font-size: 0.8rem; color: var(--gray); margin-left: 16px; border-left: 1px solid var(--border); padding-left: 16px; }
    .footer-left { display: flex; align-items: center; }
    .footer-credit { font-size: 0.875rem; color: rgba(138,154,181,0.5); }
    .back-top {
      width: 40px; height: 40px; border-radius: 50%;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--gray); cursor: pointer;
      transition: all 0.3s; font-size: 1rem;
    }
    .back-top:hover { color: var(--orange); transform: translateY(-4px); }

    /* ─── CHATBOT ─── */
    .chat-fab {
      position: fixed; bottom: 24px; right: 24px; z-index: 200;
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--orange); color: var(--white);
      border: none; cursor: pointer; font-size: 1.4rem;
      box-shadow: 0 0 20px rgba(255,106,0,0.5);
      transition: all 0.3s; display: flex; align-items: center; justify-content: center;
    }
    .chat-fab:hover { box-shadow: 0 0 35px rgba(255,106,0,0.8); transform: scale(1.1); }
    .chat-window {
      position: fixed; bottom: 96px; right: 24px; z-index: 200;
      width: 350px; height: 500px; max-height: 80vh;
      display: flex; flex-direction: column;
      background: rgba(12,16,32,0.97);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px; overflow: hidden;
      backdrop-filter: blur(24px);
      box-shadow: 0 25px 60px rgba(0,0,0,0.6);
      transform-origin: bottom right;
      animation: chatOpen 0.2s ease;
    }
    @keyframes chatOpen { from{opacity:0;transform:scale(0.9) translateY(10px)} to{opacity:1;transform:scale(1) translateY(0)} }
    .chat-window.hidden { display: none; }
    .chat-header {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05);
      display: flex; justify-content: space-between; align-items: center;
    }
    .chat-header-info { display: flex; align-items: center; gap: 10px; }
    .chat-bot-icon {
      width: 32px; height: 32px; border-radius: 50%;
      background: rgba(255,106,0,0.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem; color: var(--orange);
    }
    .chat-header-info h3 { font-size: 0.875rem; font-weight: 600; }
    .chat-header-info p { font-size: 0.75rem; color: var(--orange); display: flex; align-items: center; gap: 4px; }
    .online-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--orange); display: inline-block;
      animation: pulse 2s infinite;
    }
    .chat-close {
      background: none; border: none; color: var(--gray);
      cursor: pointer; font-size: 1.1rem; transition: color 0.2s;
    }
    .chat-close:hover { color: var(--white); }
    .chat-messages {
      flex: 1; overflow-y: auto; padding: 16px;
      display: flex; flex-direction: column; gap: 12px;
    }
    .chat-msg {
      max-width: 85%; border-radius: 16px;
      padding: 10px 14px; font-size: 0.875rem; line-height: 1.5;
    }
    .chat-msg.ai {
      align-self: flex-start;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.05);
      border-top-left-radius: 4px;
    }
    .chat-msg.user {
      align-self: flex-end;
      background: var(--orange);
      border-top-right-radius: 4px;
    }
    .chat-typing {
      align-self: flex-start;
      background: rgba(255,255,255,0.08);
      border-radius: 16px; border-top-left-radius: 4px;
      padding: 12px 16px; display: none;
    }
    .chat-typing.show { display: flex; gap: 4px; align-items: center; }
    .typing-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--gray);
      animation: typingBounce 0.6s ease-in-out infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typingBounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
    .chat-suggestions {
      padding: 0 12px 8px; display: flex; flex-wrap: wrap; gap: 6px;
    }
    .chat-suggestion {
      font-size: 0.75rem; padding: 6px 12px; border-radius: 100px;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05);
      color: var(--gray); cursor: pointer;
      transition: all 0.2s;
    }
    .chat-suggestion:hover { color: var(--orange); border-color: rgba(255,106,0,0.5); }
    .chat-input-row {
      padding: 12px 16px;
      border-top: 1px solid rgba(255,255,255,0.1);
      background: rgba(0,0,0,0.2);
      display: flex; gap: 8px;
    }
    .chat-input {
      flex: 1; background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px; padding: 8px 14px;
      color: var(--white); font-family: var(--font-body);
      font-size: 0.875rem; outline: none;
      transition: border-color 0.2s;
    }
    .chat-input:focus { border-color: rgba(255,106,0,0.5); }
    .chat-input::placeholder { color: rgba(138,154,181,0.5); }
    .chat-send {
      width: 40px; height: 40px; border-radius: 12px;
      background: var(--orange); color: var(--white);
      border: none; cursor: pointer; font-size: 0.9rem;
      transition: opacity 0.2s; display: flex;
      align-items: center; justify-content: center;
    }
    .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }

    /* SVG icons (inline) */
    svg { fill: currentColor; }

    /* Project thumb gradients */
    .grad-1 { background: linear-gradient(135deg, rgba(255,106,0,0.25), rgba(238,9,121,0.25)); }
    .grad-2 { background: linear-gradient(135deg, rgba(0,229,255,0.25), rgba(59,130,246,0.25)); }
    .grad-3 { background: linear-gradient(135deg, rgba(168,85,247,0.25), rgba(236,72,153,0.25)); }
    .grad-4 { background: linear-gradient(135deg, rgba(34,197,94,0.25), rgba(16,185,129,0.25)); }
    .grad-5 { background: linear-gradient(135deg, rgba(113,113,122,0.25), rgba(87,83,78,0.25)); }
    .grad-6 { background: linear-gradient(135deg, rgba(244,63,94,0.25), rgba(239,68,68,0.25)); }

    /* dot grid pattern on thumb */
    .project-thumb::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.2) 1px, transparent 0);
      background-size: 20px 20px;
      opacity: 0.3;
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════ NAVBAR ═══════════════════════════ -->
<nav id="navbar">
  <div class="nav-inner">
    <a class="nav-logo" onclick="scrollTo('#home')">
      <span>S</span><span>J</span>
    </a>
    <ul class="nav-links">
      <li><a href="#about" onclick="smoothScroll(event,'#about')">About</a></li>
      <li><a href="#skills" onclick="smoothScroll(event,'#skills')">Skills</a></li>
      <li><a href="#projects" onclick="smoothScroll(event,'#projects')">Projects</a></li>
      <li><a href="#experience" onclick="smoothScroll(event,'#experience')">Experience</a></li>
      <li><a href="#contact" onclick="smoothScroll(event,'#contact')">Contact</a></li>
      <li><a class="nav-hire" href="#contact" onclick="smoothScroll(event,'#contact')">Hire Me</a></li>
    </ul>
    <button class="nav-hamburger" onclick="toggleMobile()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="#about" onclick="smoothScroll(event,'#about');closeMobile()">About</a>
    <a href="#skills" onclick="smoothScroll(event,'#skills');closeMobile()">Skills</a>
    <a href="#projects" onclick="smoothScroll(event,'#projects');closeMobile()">Projects</a>
    <a href="#experience" onclick="smoothScroll(event,'#experience');closeMobile()">Experience</a>
    <a href="#contact" onclick="smoothScroll(event,'#contact');closeMobile()">Contact</a>
  </div>
</nav>

<!-- ═══════════════════════════ HERO ═══════════════════════════ -->
<section id="home">
  <canvas id="particle-canvas"></canvas>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-chip">
      <span class="hero-chip-dot"></span>
      <span id="greeting">Good morning</span>, welcome to my space
    </div>
    <h1 class="hero-name font-display">
      <span style="color:#fff">SHOBHIT </span><span class="cyan-grad">JAISWAL</span>
    </h1>
    <p class="hero-subtitle">AI/ML Engineer &nbsp;|&nbsp; Web Developer</p>
    <p class="hero-tagline">Building intelligent systems that don't just work — they think, adapt, and scale.</p>
    <p class="hero-description" style="color:var(--gray);font-size:1.1rem;margin-bottom:32px;max-width:700px;line-height:1.6">AI/ML Engineer & Full Stack Developer actively seeking internship opportunities to apply AI, GenAI, and full stack development skills in real-world projects.</p>
    <div class="hero-buttons">
      <div class="hero-row">
        <a class="btn btn-primary" onclick="smoothScrollTo('#projects')">
          View Projects
          <svg width="20" height="20" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="Shobhit_Resume.pdf" download class="btn btn-outline">
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          Download Resume
        </a>
      </div>
      <button class="btn btn-contact" onclick="smoothScrollTo('#contact')">
        <svg width="18" height="18" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Contact Me
      </button>
    </div>
  </div>
  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-arrow">
      <svg width="16" height="16" viewBox="0 0 24 24" style="color:var(--orange)"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ ABOUT ═══════════════════════════ -->
<section id="about">
  <div class="about-glow-1"></div>
  <div class="about-glow-2"></div>
  <div class="container">
    <div class="reveal">
      <p class="section-eyebrow">Who I Am</p>
      <h2 class="section-title">Unveiling <span class="grad-text">The Journey</span></h2>
    </div>
    <div class="about-grid">
      <!-- Photo -->
      <div class="photo-col reveal-left">
        <div class="photo-frame-wrap">
          <div class="photo-frame-border"></div>
          <div class="photo-area" id="photoArea">
            <img src="/assets/profile.jpg" alt="Profile" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:16px;"/>
          </div>
        </div>
        <div class="photo-name">
          <h3 class="font-display" style="font-size:1.1rem;font-weight:700">Shobhit Jaiswal</h3>
          <p style="color:var(--orange);font-size:0.85rem;margin-top:4px">AI/ML Engineer · Web Developer</p>
        </div>
        <div class="stats-grid">
          <div class="stat-card reveal">
            <div class="stat-icon" style="color:var(--orange)">
              <svg width="22" height="22" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <div class="stat-value">10+</div>
            <div class="stat-label" title="Includes both minor and major academic & personal projects">Projects Built (Minor + Major)</div>
          </div>
          <div class="stat-card reveal">
            <div class="stat-icon" style="color:var(--cyan)">
              <svg width="22" height="22" viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="17" x2="13" y2="17"/></svg>
            </div>
            <div class="stat-value">5+</div>
            <div class="stat-label">Core Skills</div>
          </div>
          <div class="stat-card reveal">
            <div class="stat-icon" style="color:var(--orange)">
              <svg width="22" height="22" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
            </div>
            <div class="stat-value">2+</div>
            <div class="stat-label">Years Exp.</div>
          </div>
          <div class="stat-card reveal">
            <div class="stat-icon" style="color:var(--cyan)">
              <svg width="22" height="22" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="stat-value">200+</div>
            <div class="stat-label">DSA Problems</div>
          </div>
        </div>
      </div>
      <!-- Text -->
      <div class="about-text reveal-right">
        <p>My journey into technology began in 2024 with a strong curiosity about how intelligent systems work and how scalable applications are built.</p>
        <p>Since then, I have been consistently learning and building in the domains of AI/ML and full stack development, transforming theoretical knowledge into real-world projects.</p>
        <p>I specialize in combining machine learning with modern web technologies to create intelligent, scalable, and user-focused applications.</p>
        <p>Alongside development, I have solved <strong>200+ Data Structures & Algorithms problems</strong>, which has significantly strengthened my problem-solving ability and understanding of efficient system design.</p>
        <p><strong>I focus on:</strong></p>
        <ul style="color:var(--gray);line-height:1.8;margin-left:20px">
          <li>Building AI-powered applications, not just models</li>
          <li>Designing scalable backend systems for ML integration</li>
          <li>Creating responsive and high-performance frontend interfaces</li>
          <li>Writing optimized and clean code</li>
        </ul>
        <p>I am currently looking for internship opportunities where I can contribute, learn, and grow while working on impactful real-world problems.</p>
        <div class="quote-block">
          <p>"Great software feels simple — but is powered by deep engineering."</p>
        </div>
        <div class="currently-tags">
          <span class="label">Currently exploring:</span>
          <span class="tag tag-cyan">Large Language Models</span>
          <span class="tag tag-orange">Agentic AI</span>
          <span class="tag tag-gray">System Architecture</span>
          <span class="tag tag-cyan">Web3 Integrations</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ SKILLS ═══════════════════════════ -->
<section id="skills">
  <div class="container">
    <div class="skills-header">
      <div class="reveal">
        <h2 class="skills-title font-display">Technical <span style="color:var(--orange)">Arsenal</span></h2>
        <p class="skills-subtitle">A meticulously curated stack of technologies I use to bring ideas to life.</p>
      </div>
      <div class="skill-tabs reveal">
        <button class="skill-tab active" onclick="switchSkill(this,'aiml')">AI/ML</button>
        <button class="skill-tab" onclick="switchSkill(this,'frontend')">Frontend</button>
        <button class="skill-tab" onclick="switchSkill(this,'backend')">Backend</button>
        <button class="skill-tab" onclick="switchSkill(this,'tools')">Tools</button>
      </div>
    </div>
    <div class="skills-grid" id="skillsGrid"></div>
  </div>
</section>

<!-- ═══════════════════════════ PROJECTS ═══════════════════════════ -->
<section id="projects">
  <div class="container">
    <div class="projects-header reveal">
      <h2 class="projects-title font-display">Featured <span class="grad-text">Work</span></h2>
      <div class="filter-tabs">
        <button class="filter-tab active" onclick="filterProjects(this,'all')">All</button>
        <button class="filter-tab" onclick="filterProjects(this,'AI/ML')">AI/ML</button>
        <button class="filter-tab" onclick="filterProjects(this,'Full Stack')">Full Stack</button>
        <button class="filter-tab" onclick="filterProjects(this,'Full Stack + GenAI')">Full Stack + GenAI</button>
        <button class="filter-tab" onclick="filterProjects(this,'Web')">Web</button>
      </div>
    </div>
    <div class="projects-grid" id="projectsGrid"></div>
  </div>
</section>

<!-- ═══════════════════════════ EXPERIENCE ═══════════════════════════ -->
<section id="experience">
  <div class="container">
    <h2 class="experience-title font-display reveal">Professional <span style="color:var(--orange)">Journey</span></h2>
    <div class="timeline">
      <div class="timeline-line"></div>
      <div id="timelineItems"></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ CONTACT ═══════════════════════════ -->
<section id="contact">
  <div class="contact-glow"></div>
  <div class="container">
    <div class="contact-grid">
      <div class="reveal-left">
        <h2 class="contact-heading font-display">Let's Build<br><span class="grad-text">Something.</span></h2>
        <p class="contact-sub">Whether you have a question, a project idea, or just want to say hi, I'll get back to you!</p>
        <div class="contact-info">
          <div class="contact-info-item">
            <div class="contact-info-icon" style="color:var(--orange)">✉</div>
            <div>
              <p>Email</p>
              <a href="mailto:shobhitjais2607@gmail.com">shobhitjais2607@gmail.com</a>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon" style="color:var(--cyan)">📍</div>
            <div>
              <p>Location</p>
              <span>Noida, India 🇮🇳</span>
            </div>
          </div>
        </div>
        <div class="social-links">
          <a class="social-btn" href="#" title="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
          </a>
          <a class="social-btn" href="#" title="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a class="social-btn" href="#" title="Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
          </a>
        </div>
      </div>
      <div class="reveal-right">
        <form class="contact-form" id="contactForm" onsubmit="sendEmail(event)">
          <div class="form-group">
            <label>Your Name</label>
            <input type="text" name="user_name" placeholder="John Doe" required/>
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="user_email" placeholder="john@example.com" required/>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="message" rows="5" placeholder="Tell me about your project..." required></textarea>
          </div>
          <button type="submit" class="btn-send" id="sendBtn">
            <span id="sendText">Send Message ✈</span>
            <div id="sendSpinner" class="spinner" style="display:none"></div>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

